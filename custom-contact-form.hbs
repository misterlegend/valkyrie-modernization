{{!< default}}

{{! The tag above means: Insert everything in this file into the {body} of the default.hbs template. }}

{{#post}}

    <!-- POST INFO WRAPPER -->
    <div class="page-info-wrapper post-presentation lazy active {{#if feature_image}}background{{else}}background-pattern{{/if}}"
    {{#if feature_image}}data-src="{{feature_image}}"{{/if}}>
        <div class="gradient gradient1">
            <div class="container text-center">
                <div class="row">
                    <div class="col-sm-12 col-md col-lg col-xs-12">
                        <h1 class="animated fadeInUp">{{title}}</h1>
                        <p class="animated fadeInUp">{{excerpt words="10"}}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{! Latest Post - Go to partials/latestPost.hbs to view this partial. }}
    {{> "latest-post"}}

    <div id="main" class="form-template">
        <div class="container">
            <div class="row d-flex align-items-center">
                <div class="col-xs-12 col-sm-12 col-lg-8 col-md-6 post-presentation">
                    {{{content}}}
                </div>
                <div class="col-xs-12 col-sm-12 col-lg-4 col-md-6 post-presentation">
                    <form class="form-control" id="fs-frm" name="department-contact-form" accept-charset="utf-8" action="https://formspree.io/f/mrgrjzdq" method="post">
  <fieldset id="fs-frm-inputs">
    <label for="full-name">Name (Company if applicable)</label>
    <input class="form-control" type="text" name="name" id="full-name" placeholder="Enter name..." required="">
    <label for="email-address">Email Address</label>
    <input class="form-control" type="email" name="_replyto" id="email-address" placeholder="Enter email..." required="">
    <label for="writer">Writer</label>
    <select class="form-control" name="writer" id="writer" required="">
      <option class="form-control" value="" selected="" disabled="">Select</option>
      <option class="form-control" value="Den-Fi">Den-Fi</option>
      <option class="form-control" value="Ishca">Ishca</option>
      <option class="form-control" value="Flux">Flux</option>
      <option class="form-control" value="listener">listener</option>
      <option class="form-control" value="Claire">Claire Z.</option>
    </select>
    <label for="message">Message</label>
    <textarea class="form-control" rows="5" name="message" id="message" placeholder="Enter your message..." required=""></textarea>
    <input class="form-control" type="hidden" name="_subject" id="email-subject" value="Writer Contact Form Submission">
  </fieldset>
  <input class="form-control" type="submit" value="Send Message">
</form>
                </div>
            </div>
        </div>
    </div>

    <div class="b-frame"></div>

{{/post}}
